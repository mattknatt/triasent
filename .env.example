# Copy to .env (gitignored) and fill in — docker-compose.yml reads these.
# Generate strong values, e.g.:  openssl rand -hex 16
DB_PASSWORD=changeme
RABBITMQ_PASSWORD=changeme

# OAuth client secrets — authservice encodes them; bff/botservice present them.
# The same value must be used by the server and its client (compose wires that for you).
GATEWAY_CLIENT_SECRET=changeme
BOT_CLIENT_SECRET=changeme

# NOTE: botservice's LLM credentials (LLM_API_URL / LLM_API_KEY / LLM_API_MODEL) live in
# botservice/.env, which compose loads via env_file — they are not duplicated here.
